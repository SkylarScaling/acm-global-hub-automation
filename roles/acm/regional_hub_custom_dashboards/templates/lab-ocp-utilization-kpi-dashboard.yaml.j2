kind: ConfigMap
apiVersion: v1
metadata:
  name: lab-utilization-caas-kpi-dashboard
  namespace: open-cluster-management-observability
  labels:
    grafana-custom-dashboard: "true"
  annotations:
    observability.open-cluster-management.io/dashboard-folder: CaaS_KPI's
data:
  lab-utilization-caas-kpis.json: |-
    {% raw %}
    {
      "annotations": {
        "list": []
      },
      "editable": true,
      "fiscalYearStartMonth": 0,
      "graphTooltip": 0,
      "links": [],
      "liveNow": false,
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
          "id": 1,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "max by (cluster) (cluster:node_cpu:ratio{cluster!=\"\"}) * 100", "legendFormat": "{{cluster}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Cluster CPU Utilization (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
          "id": 2,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "100 - (sum by (cluster) (node_memory_MemAvailable_bytes{job=\"node-exporter\", cluster!=\"\"}) / sum by (cluster) (node_memory_MemTotal_bytes{job=\"node-exporter\", cluster!=\"\"}) * 100)", "legendFormat": "{{cluster}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Cluster Memory Utilization (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
          "id": 3,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "100 - (sum by (cluster) (node_filesystem_avail_bytes{job=\"node-exporter\", fstype=~\"ext4|xfs\", cluster!=\"\"}) / sum by (cluster) (node_filesystem_size_bytes{job=\"node-exporter\", fstype=~\"ext4|xfs\", cluster!=\"\"}) * 100)", "legendFormat": "{{cluster}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Cluster Disk Space Utilization (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
          "id": 4,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "max by (cluster) (etcd_debugging_mvcc_db_total_size_in_bytes / etcd_server_quota_backend_bytes) * 100", "legendFormat": "{{cluster}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Cluster etcd Database Quota Utilized (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
          "id": 5,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "label_replace((100 - (avg by (cluster, instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\", cluster!=\"\", instance!=\"\"}[15m])) * 100)) * on(cluster, instance) group_left(role) label_replace(label_replace(max by (cluster, node) (kube_node_role{role=~\"master|control-plane\"}), \"role\", \"control-plane\", \"node\", \".*\") or (max by (cluster, node, role) (kube_node_role{role!~\"master|control-plane|worker\"}) unless on(cluster, node) kube_node_role{role=~\"master|control-plane\"}) or label_replace(max by (cluster, node) (kube_node_role{role=\"worker\"}) unless on(cluster, node) kube_node_role{role!=\"worker\"}, \"role\", \"worker\", \"node\", \".*\"), \"instance\", \"$1\", \"node\", \"(.*)\"), \"instance\", \"$1\", \"instance\", \"^([^.]+)[.].*$\")", "legendFormat": "{{cluster}} - {{role}} - {{instance}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Node CPU Utilized (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
          "id": 6,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "label_replace((100 - (sum by (cluster, instance) (node_memory_MemAvailable_bytes{job=\"node-exporter\", cluster!=\"\", instance!=\"\"}) / sum by (cluster, instance) (node_memory_MemTotal_bytes{job=\"node-exporter\", cluster!=\"\", instance!=\"\"}) * 100)) * on(cluster, instance) group_left(role) label_replace(label_replace(max by (cluster, node) (kube_node_role{role=~\"master|control-plane\"}), \"role\", \"control-plane\", \"node\", \".*\") or (max by (cluster, node, role) (kube_node_role{role!~\"master|control-plane|worker\"}) unless on(cluster, node) kube_node_role{role=~\"master|control-plane\"}) or label_replace(max by (cluster, node) (kube_node_role{role=\"worker\"}) unless on(cluster, node) kube_node_role{role!=\"worker\"}, \"role\", \"worker\", \"node\", \".*\"), \"instance\", \"$1\", \"node\", \"(.*)\"), \"instance\", \"$1\", \"instance\", \"^([^.]+)[.].*$\")", "legendFormat": "{{cluster}} - {{role}} - {{instance}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Node Memory Utilized (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
          "id": 7,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "label_replace((100 - (sum by (cluster, instance) (node_filesystem_avail_bytes{job=\"node-exporter\", fstype=~\"ext4|xfs\", cluster!=\"\", instance!=\"\"}) / sum by (cluster, instance) (node_filesystem_size_bytes{job=\"node-exporter\", fstype=~\"ext4|xfs\", cluster!=\"\", instance!=\"\"}) * 100)) * on(cluster, instance) group_left(role) label_replace(label_replace(max by (cluster, node) (kube_node_role{role=~\"master|control-plane\"}), \"role\", \"control-plane\", \"node\", \".*\") or (max by (cluster, node, role) (kube_node_role{role!~\"master|control-plane|worker\"}) unless on(cluster, node) kube_node_role{role=~\"master|control-plane\"}) or label_replace(max by (cluster, node) (kube_node_role{role=\"worker\"}) unless on(cluster, node) kube_node_role{role!=\"worker\"}, \"role\", \"worker\", \"node\", \".*\"), \"instance\", \"$1\", \"node\", \"(.*)\"), \"instance\", \"$1\", \"instance\", \"^([^.]+)[.].*$\")", "legendFormat": "{{cluster}} - {{role}} - {{instance}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Node Disk Space Utilized (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 75 },
                  { "color": "red", "value": 85 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
          "id": 8,
          "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "label_replace((max by (cluster, pod) (etcd_debugging_mvcc_db_total_size_in_bytes)) / (max by (cluster, pod) (etcd_server_quota_backend_bytes)) * 100, \"pod\", \"$1\", \"pod\", \"^([^.]+)[.].*$\")", "legendFormat": "{{cluster}} - {{pod}}", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Instance etcd Database Quota Utilized (%)",
          "type": "bargauge"
        }
      ],
      "refresh": "1m",
      "schemaVersion": 39,
      "tags": [
        "caas",
        "kpi",
        "utilization"
      ],
      "templating": {
        "list": [
          {
            "hide": 0,
            "includeAll": false,
            "multi": false,
            "name": "datasource",
            "query": "prometheus",
            "refresh": 1,
            "type": "datasource"
          }
        ]
      },
      "time": {
        "from": "now-7d",
        "to": "now"
      },
      "timezone": "browser",
      "title": "Lab CaaS KPIs: Openshift Utilization",
      "uid": "lab-ocp-utilization-caas-kpis",
      "version": 1
    }
    {% endraw %}