            "textMode": "auto"
          },
          "pluginVersion": "10.3.1",
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "$datasource"
              },
              "editorMode": "code",
              "expr": "sum by (severity) (ALERTS{alertstate=\"firing\"})",
              "legendFormat": "{{severity}}",
              "range": true,
              "refId": "A"
            }
          ],
          "title": "Platform Incident Volume (Active Alerts)",
          "type": "stat"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              },
              "mappings": [],
