          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "$datasource"
              },
              "editorMode": "code",
              "expr": "max by (cluster, instance) (instance:node_memory_utilisation:ratio) * 100",
              "legendFormat": "{{cluster}} - {{instance}}",
              "range": true,
              "refId": "A"
            }
          ],
          "title": "Node Memory Utilization (%)",
          "type": "timeseries"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "axisCenteredZero": false,
