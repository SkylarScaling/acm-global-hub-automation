              "editorMode": "code",
              "expr": "100 - (sum by (cluster, instance) (node_filesystem_avail_bytes{fstype=~\"ext4|xfs\"}) / sum by (cluster, instance) (node_filesystem_size_bytes{fstype=~\"ext4|xfs\"}) * 100)",
