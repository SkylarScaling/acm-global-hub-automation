              "editorMode": "code",
              "expr": "max by (cluster, instance) (instance:node_cpu_utilisation:rate1m) * 100",
              "legendFormat": "{{cluster}} - {{instance}}",
              "range": true,
              "refId": "A"
            }
          ],
          "title": "Node CPU Utilization (%)",
          "type": "timeseries"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
