            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "avg(up{job=~\"apiserver|kube-apiserver\"}) * 100", "legendFormat": "Fleet", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "API Server Availability (%)",
          "type": "bargauge"
        },
        {
