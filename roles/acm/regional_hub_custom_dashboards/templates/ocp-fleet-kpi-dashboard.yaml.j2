kind: ConfigMap
apiVersion: v1
metadata:
  name: ocp-fleet-overview-caas-kpi-dashboard
  namespace: open-cluster-management-observability
  labels:
    grafana-custom-dashboard: "true"
  annotations:
    observability.open-cluster-management.io/dashboard-folder: CaaS_KPI's
data:
  fleet-overview-caas-kpis.json: |-
    {% raw %}
    {
      "annotations": { "list": [] },
      "editable": true,
      "fiscalYearStartMonth": 0,
      "graphTooltip": 0,
      "links": [],
      "liveNow": false,
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "orange", "value": 90 },
                  { "color": "yellow", "value": 95 },
                  { "color": "green", "value": 99 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
          "id": 1,
          "options": { "displayMode": "basic", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "( (avg(up{job=~\"apiserver|kube-apiserver\"}) * 0.35) + (avg(up{job=\"etcd\"}) * 0.35) + (avg(kube_node_status_condition{condition=\"Ready\", status=\"true\"}) * 0.15) + (avg(up{namespace=\"openshift-ingress\"}) * 0.10) + (avg(up{job=\"console\"}) * 0.05) ) * 100", "legendFormat": "Fleet", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Fleet Health Score (%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "max": 100, "min": 0,
              "mappings": [
                {
                  "options": { "match": "null", "result": { "text": "No Data" } },
                  "type": "special"
                },
                {
                  "options": { "from": 99.99, "to": 100, "result": { "color": "green", "index": 1, "text": "Meets Target" } },
                  "type": "range"
                },
                {
                  "options": { "from": 0, "to": 99.9899, "result": { "color": "red", "index": 2, "text": "Failing Target" } },
                  "type": "range"
                }
              ],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "green", "value": 99.99 }
                ]
              },
              "unit": "percent"
            }
          },
          "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
          "id": 2,
          "options": { "displayMode": "basic", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "avg( (avg by (cluster) (avg_over_time((max by (cluster, instance) (up{job=~\"apiserver|kube-apiserver\"}))[30d:5m]))) and on(cluster) max by (cluster) (up{job=~\"apiserver|kube-apiserver\"}) ) * 100", "legendFormat": "Fleet", "instant": true, "range": false, "refId": "A" }
          ],
          "title": "Fleet API 30-Day SLA (Target: 99.99%)",
          "type": "bargauge"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "fieldConfig": {
