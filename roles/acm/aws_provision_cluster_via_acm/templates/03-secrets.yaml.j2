---
apiVersion: v1
kind: Secret
metadata:
  name: "{{ ocp_cluster.name }}-aws-creds"
  namespace: "{{ ocp_cluster.name }}"
stringData:
  aws_access_key_id: "{{ aws.aws_access_key_id }}"
  aws_secret_access_key: "{{ aws.aws_secret_access_key }}"
type: Opaque

---
apiVersion: v1
kind: Secret
metadata:
  name: "{{ ocp_cluster.name }}-pull-secret"
  namespace: "{{ ocp_cluster.name }}"
stringData:
  .dockerconfigjson: '{{ pull_secret | to_json }}'
type: kubernetes.io/dockerconfigjson

---
apiVersion: v1
kind: Secret
metadata:
  name: "{{ ocp_cluster.name }}-install-config"
  namespace: "{{ ocp_cluster.name }}"
stringData:
  install-config.yaml: |
    apiVersion: v1
    baseDomain: {{ base_domain }}
    compute:
    - architecture: amd64
      hyperthreading: Enabled
      name: worker
      replicas: {{ install_config.workers.replicas }}
      platform:
        aws:
          type: {{ install_config.workers.instance_type }}
    controlPlane:
      architecture: amd64
      hyperthreading: Enabled
      name: master
      replicas: 3
      platform:
        aws:
          type: {{ install_config.control_plane.instance_type }}
    metadata:
      name: {{ ocp_cluster.name }}
    networking:
      clusterNetwork:
      - cidr: 10.128.0.0/14
        hostPrefix: 23
      machineNetwork:
      - cidr: 10.0.0.0/16
      networkType: OVNKubernetes
      serviceNetwork:
      - 172.30.0.0/16
    platform:
      aws:
        region: {{ aws.aws_region }}
    pullSecret: '{{ pull_secret | to_json }}'
    sshKey: |
      {{ ssh_key }}
type: Opaque